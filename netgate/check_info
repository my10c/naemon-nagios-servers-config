import os
import sys
import socket
import argparse
import subprocess
from time import strftime

__progname__    = os.path.basename(__file__)
__author__      = 'Luc Suryo'
__copyright__   = 'Copyright 2009 - ' + strftime('%Y') + ' © Badassops LLC'
__license__     = 'License 3-Clause BSD, https://opensource.org/licenses/BSD-3-Clause ♥'
__version__     = '1.0'
__email__       = '<luc@badassops.com>'
__info__        = f'{__version__}\n{__copyright__}\nLicense {__license__}\n\n' +\
                  f'Written by {__author__} {__email__}\n'
__description__ = 'nagios check script to check the uptime of the server'
__usage_txt__   = 'no argument required'
__host__        = socket.gethostname().split('.', 1)[0]

# Defaults nagios exit status
OK        = 0
WARN      = 1
CRIT      = 2
UNKNOWN   = 3
# NOTE:  create a crontab : once week : run by root: /etc/rc.banner > /tmp/banner.out
#        this due it must run as root to get more usefull information
BANNER    = ['cat' , '/tmp/banner.out']
MODEL     = ['sysctl', 'dev.netgate.model']
CPU       = ['cat', '/var/run/dmesg.boot']

def get_device_info():
    """
    get the netgate information
    """
    info_product = ''
    info_serial  = ''
    info_version = ''
    info_wan     = ''
    info_lan     = ''
    info_cpu     = ''
    try:
        with subprocess.Popen(MODEL, stdout=subprocess.PIPE, bufsize=1, text=True) as process:
            for line in process.stdout:
                info_product = f'{line.rstrip().split()[1]}'
                if info_product == 'unknown':
                    info_product = 'None Netgate Device'

        if info_product == 'None Netgate Device':
            with subprocess.Popen(CPU, stdout=subprocess.PIPE, bufsize=1, text=True) as process:
                for line in process.stdout:
                    if  line.rstrip().startswith('CPU'):
                        info_cpu = f'{line.rstrip().split()[1]}' + ' ' + f'{line.rstrip().split()[2]}'
                        break

        if_wan = 0
        if_lan = 0
        with subprocess.Popen(BANNER, stdout=subprocess.PIPE, bufsize=1, text=True) as process:
            for line in process.stdout:
                if info_product == '2100':
                    if 'Serial:' in line:
                        info_serial  = f'{line.rstrip().split()[1]}'

                if ['4100', '6100'] in info_product:
                    if 'Serial:' in line:
                        info_serial  = f'{line.rstrip().split()[4]}'

                if info_product == 'None Netgate Device':
                    if 'Serial:' in line:
                        info_serial  = f'{line.rstrip().split()[5]}'

                if 'Welcome' in line:
                    info_version = f'{line.rstrip().split()[6]}'

                if 'WAN' in line:
                    info_wan = f'{line.rstrip().split()[6].split("/")[0]}'
                    if_wan = 1

                if 'LAN' in line:
                    info_lan = f'{line.rstrip().split()[6].split("/")[0]}'
                    if_lan = 1

                if 'v6' in line and if_wan:
                    info_wan_v6 = f'{line.rstrip().split()[1].split("/")[0]}'
                    if_wan = 0
                    info_wan = f'{info_wan} / {info_wan_v6}'

                if 'v6' in line and if_lan:
                    info_lan_v6 = f'{line.rstrip().split()[1].split("/")[0]}'
                    if_lan = 0
                    info_lan = f'{info_lan} / {info_lan_v6}'

    except Exception as err:
        print(f'Errored: {err}')
        sys.exit(UNKNOWN)

    if info_product == 'None Netgate Device':
        print(f'OK: Model {info_cpu} - Serial {info_serial} - Version {info_version}' +\
              f' - WAN {info_wan} - LAN {info_lan}')
    else:
        print(f'OK: Model {info_product} - Serial {info_serial} - Version {info_version}' +\
              f' - WAN {info_wan} - LAN {info_lan}')
    sys.exit(OK)

if __name__ == "__main__":
  # Process giving arguments
    parser = argparse.ArgumentParser(usage = __usage_txt__, description = __description__,
        formatter_class = argparse.RawDescriptionHelpFormatter, conflict_handler='resolve')
    parser.add_argument('-v', '--version', action = 'version', version = __info__)
    options = parser.parse_args()
    get_device_info()
