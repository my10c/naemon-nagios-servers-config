import os
import sys
import socket
import argparse
import subprocess
from time import strftime

__progname__    = os.path.basename(__file__)
__author__      = 'Luc Suryo'
__copyright__   = 'Copyright 2009 - ' + strftime('%Y') + ' © Badassops LLC'
__license__     = 'License 3-Clause BSD, https://opensource.org/licenses/BSD-3-Clause ♥'
__version__     = '1.0'
__email__       = '<luc@badassops.com>'
__info__        = f'{__version__}\n{__copyright__}\nLicense {__license__}\n\n' +\
                  f'Written by {__author__} {__email__}\n'
__description__ = 'nagios check script to check the uptime of the server'
__usage_txt__   = '<--critical value>'
__host__        = socket.gethostname().split('.', 1)[0]

DEFAULT_CRITICAL = 1200
_HELP_CRITICAL = f'default critical uptime in seconds, default to {DEFAULT_CRITICAL}'

# Defaults nagios exit status
OK               = 0
WARN             = 1
CRIT             = 2
UNKNOWN          = 3
UPTIME_CMD = '/usr/bin/uptime'

def uptime_check(critical):
    """
    critical : critical level
    """
    try:
        result = subprocess.run(UPTIME_CMD, capture_output=True,\
                   text=True, check=True, shell=True)
    except Exception as err:
        print(f'Errored: {err}')
        sys.exit(UNKNOWN)

    output = str(result.stdout).strip().split()
    # 2:23AM  up 6 days, 59 mins, 2 users, load averages: 0.31, 0.26, 0.25
    # 5:14PM  up 2 mins, 2 users, load averages: 1.74, 0.89, 0.37

    humanInfo   = 'unknown'
    daysSeconds = 0
    hourSeconds = 0
    minSeconds  = 0
    minutes     = 0

    if 'day' in output[3]:
        # up for days
        daysSeconds = 86400 * int(output[2].replace(',',''))
        humanInfo = f'{int(output[2].replace(",",""))} days+'
        if ':' in output[4]:
            hourSeconds = 3600 * int(output[4].split(':')[0].replace(',',''))
            minSeconds  = 60   * int(output[4].split(':')[1].replace(',',''))
        else:
            minSeconds = 60    * int(output[4].replace(',',''))
    elif ':' in output[2]:
        # up for hours
        humanInfo = f'{int(output[2].split(":")[0].replace(",",""))} hours+'
        hourSeconds = 3600 * int(output[2].split(':')[0].replace(',',''))
        minSeconds  = 60   * int(output[2].split(':')[1].replace(',',''))
    elif 'mins' in output[3]:
        # up for mins
        minutes     = int(output[2])
        minSeconds  = 60 * minutes
        humanInfo   = f'{minSeconds} seconds is {minutes} minutes+'

    uptime_sec = daysSeconds + hourSeconds + minSeconds
    if uptime_sec < critical:
        print(f'CRITICAL - {__host__} server uptime is {humanInfo} seconds ' + \
              f'(~{minutes} minutes) |uptime={uptime_sec};;{critical};')
        sys.exit(2)
    else:
        print(f'OK - {__host__} server uptime is {uptime_sec} seconds ' + \
              f'is {humanInfo} |uptime={uptime_sec};;{critical};')
        sys.exit(0)

if __name__ == "__main__":
  # Process giving arguments
    parser = argparse.ArgumentParser(usage = __usage_txt__, description = __description__,
        formatter_class = argparse.RawDescriptionHelpFormatter, conflict_handler='resolve')

    parser.add_argument('-v', '--version', action = 'version', version = __info__)

    parser.add_argument('-c', '--critical', action = 'store', dest = 'critical',
        default = DEFAULT_CRITICAL, help = _HELP_CRITICAL)

    options = parser.parse_args()
    uptime_check(int(options.critical))
